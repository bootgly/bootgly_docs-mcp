{
  "name": "bootgly-docs-mcp",
  "displayName": "Bootgly Docs MCP",
  "description": "MCP server for Bootgly PHP Framework documentation. Search and access Bootgly docs directly from GitHub Copilot Chat.",
  "version": "1.1.0",
  "publisher": "bootgly",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/bootgly/bootgly_docs-mcp"
  },
  "homepage": "https://docs.bootgly.com",
  "bugs": {
    "url": "https://github.com/bootgly/bootgly_docs-mcp/issues"
  },
  "main": "./out/extension.js",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "mcp-server",
    "mcp",
    "bootgly",
    "php",
    "documentation",
    "framework"
  ],
  "activationEvents": [],
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "bootglyDocs",
        "label": "Bootgly Docs"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.99.0",
    "@types/node": "^22",
    "typescript": "^5.9.2"
  }
}
